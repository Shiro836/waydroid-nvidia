From: waydroid-nvidia project <gazikkamalov2@gmail.com>
Subject: [PATCH] surfaceflinger: prop-tunable vsync snap window for >333 Hz displays

VSyncDispatchTimerQueue's minVsyncDistance (kSnapToSameVsyncWithin) is
hardcoded to 3 ms. On displays with a vsync period at or below 3 ms
(>= ~333 Hz) every predicted vsync falls inside the snap window of the
previously armed one, timeslots collapse, the dispatch timer computes an
INT64_MAX wakeup and parks forever: no vsync callbacks, no frames.

Make the window overridable via debug.sf.snap_to_same_vsync_within_ns
(default unchanged, 3 ms). Waydroid-on-500Hz sets 1000000 (1 ms).

diff --git a/services/surfaceflinger/Scheduler/VsyncSchedule.cpp b/services/surfaceflinger/Scheduler/VsyncSchedule.cpp
index 3a918a1660..db2fa0aabd 100644
--- a/services/surfaceflinger/Scheduler/VsyncSchedule.cpp
+++ b/services/surfaceflinger/Scheduler/VsyncSchedule.cpp
@@ -16,6 +16,8 @@
 
 #define ATRACE_TAG ATRACE_TAG_GRAPHICS
 
+#include <android-base/properties.h>
+
 #include <scheduler/Fps.h>
 #include <scheduler/Timer.h>
 
@@ -94,9 +96,16 @@ VsyncSchedule::DispatchPtr VsyncSchedule::createDispatch(VsyncTracker& tracker)
     constexpr std::chrono::nanoseconds kGroupDispatchWithin = 500us;
     constexpr std::chrono::nanoseconds kSnapToSameVsyncWithin = 3ms;
 
+    // A snap window >= the vsync period collapses all timeslots into one and
+    // parks the dispatch timer forever (INT64_MAX wakeup). Displays faster
+    // than ~333 Hz therefore need a smaller window than the 3 ms default.
+    const nsecs_t snapToSameVsyncWithin =
+            android::base::GetIntProperty("debug.sf.snap_to_same_vsync_within_ns",
+                                          static_cast<int64_t>(kSnapToSameVsyncWithin.count()));
+
     return std::make_unique<VSyncDispatchTimerQueue>(std::make_unique<Timer>(), tracker,
                                                      kGroupDispatchWithin.count(),
-                                                     kSnapToSameVsyncWithin.count());
+                                                     snapToSameVsyncWithin);
 }
 
 VsyncSchedule::ControllerPtr VsyncSchedule::createController(VsyncTracker& tracker,
