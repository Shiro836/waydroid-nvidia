From 07f6438db1dd0c9db81ef6bbe98534817b519a4b Mon Sep 17 00:00:00 2001
From: forsen <gazikkamalov2@gmail.com>
Date: Fri, 10 Jul 2026 20:06:20 +0300
Subject: [PATCH 2/2] venus/vtest: implement bo_create_from_dma_buf over the
 vtest socket

Send the dmabuf via SCM_RIGHTS (new vtest_send_fd) with
VCMD_RESOURCE_IMPORT_BLOB; the reply carries the res_id. Advertise
has_dma_buf_import when the server supports the venus fd commands.
Enables VK_ANDROID_external_memory_android_hardware_buffer (gralloc
buffer import) for venus-over-vtest in containers.
---
 src/virtio/vtest/vtest_protocol.h     |  7 ++
 src/virtio/vulkan/vn_renderer_vtest.c | 93 ++++++++++++++++++++++++++-
 2 files changed, 98 insertions(+), 2 deletions(-)

diff --git a/src/virtio/vtest/vtest_protocol.h b/src/virtio/vtest/vtest_protocol.h
index 88ccdd7..c8a1bbf 100644
--- a/src/virtio/vtest/vtest_protocol.h
+++ b/src/virtio/vtest/vtest_protocol.h
@@ -96,6 +96,8 @@
 
 /* export a sync_file fd for a pending venus sync point */
 #define VCMD_SYNC_EXPORT_SYNC_FILE 39
+/* import a dmabuf fd as a blob resource attached to the context */
+#define VCMD_RESOURCE_IMPORT_BLOB 40
 
 #define VCMD_RES_CREATE_SIZE 10
 #define VCMD_RES_CREATE_RES_HANDLE 0 /* must be 0 since protocol version 3 */
@@ -241,6 +243,11 @@ enum vcmd_sync_export_sync_file_status {
 #define VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_HI 2
 /* resp status dword, then 1 fd if status == OK */
 
+#define VCMD_RESOURCE_IMPORT_BLOB_SIZE 2
+#define VCMD_RESOURCE_IMPORT_BLOB_SIZE_LO 0
+#define VCMD_RESOURCE_IMPORT_BLOB_SIZE_HI 1
+/* followed by 1 fd; resp res_id (0 = failure) */
+
 enum vcmd_submit_cmd2_flag {
    VCMD_SUBMIT_CMD2_FLAG_RING_IDX = 1 << 0,
    VCMD_SUBMIT_CMD2_FLAG_IN_FENCE_FD = 1 << 1,
diff --git a/src/virtio/vulkan/vn_renderer_vtest.c b/src/virtio/vulkan/vn_renderer_vtest.c
index fb876a0..7aaebd2 100644
--- a/src/virtio/vulkan/vn_renderer_vtest.c
+++ b/src/virtio/vulkan/vn_renderer_vtest.c
@@ -145,6 +145,31 @@ vtest_receive_fd(struct vtest *vtest)
    return *((int *)CMSG_DATA(cmsg));
 }
 
+static int
+vtest_send_fd(struct vtest *vtest, int fd)
+{
+   char cmsg_buf[CMSG_SPACE(sizeof(fd))];
+   char dummy = 0;
+   struct iovec iov = {
+      .iov_base = &dummy,
+      .iov_len = sizeof(dummy),
+   };
+   struct msghdr msg = {
+      .msg_iov = &iov,
+      .msg_iovlen = 1,
+      .msg_control = cmsg_buf,
+      .msg_controllen = sizeof(cmsg_buf),
+   };
+   struct cmsghdr *cmsg = CMSG_FIRSTHDR(&msg);
+   cmsg->cmsg_level = SOL_SOCKET;
+   cmsg->cmsg_type = SCM_RIGHTS;
+   cmsg->cmsg_len = CMSG_LEN(sizeof(fd));
+   memcpy(CMSG_DATA(cmsg), &fd, sizeof(fd));
+
+   const ssize_t ret = sendmsg(vtest->sock_fd, &msg, MSG_NOSIGNAL);
+   return ret > 0 ? 0 : -ECONNRESET;
+}
+
 static void
 vtest_write(struct vtest *vtest, const void *buf, size_t size)
 {
@@ -481,6 +506,32 @@ vtest_vcmd_sync_wait(struct vtest *vtest,
    return vtest_receive_fd(vtest);
 }
 
+static uint32_t
+vtest_vcmd_resource_import_blob(struct vtest *vtest, uint64_t size, int fd)
+{
+   uint32_t vtest_hdr[VTEST_HDR_SIZE];
+   uint32_t vcmd_import[VCMD_RESOURCE_IMPORT_BLOB_SIZE];
+
+   vtest_hdr[VTEST_CMD_LEN] = VCMD_RESOURCE_IMPORT_BLOB_SIZE;
+   vtest_hdr[VTEST_CMD_ID] = VCMD_RESOURCE_IMPORT_BLOB;
+   vcmd_import[VCMD_RESOURCE_IMPORT_BLOB_SIZE_LO] = (uint32_t)size;
+   vcmd_import[VCMD_RESOURCE_IMPORT_BLOB_SIZE_HI] = (uint32_t)(size >> 32);
+
+   vtest_write(vtest, vtest_hdr, sizeof(vtest_hdr));
+   vtest_write(vtest, vcmd_import, sizeof(vcmd_import));
+
+   if (vtest_send_fd(vtest, fd))
+      return 0;
+
+   vtest_read(vtest, vtest_hdr, sizeof(vtest_hdr));
+   assert(vtest_hdr[VTEST_CMD_ID] == VCMD_RESOURCE_IMPORT_BLOB);
+
+   uint32_t res_id;
+   vtest_read(vtest, &res_id, sizeof(res_id));
+
+   return res_id;
+}
+
 static int
 vtest_vcmd_sync_export_sync_file(struct vtest *vtest,
                                  uint32_t sync_id,
@@ -727,6 +778,44 @@ vtest_bo_export_dma_buf(struct vn_renderer *renderer,
    return shareable ? os_dupfd_cloexec(bo->res_fd) : -1;
 }
 
+static VkResult
+vtest_bo_create_from_dma_buf(struct vn_renderer *renderer,
+                             VkDeviceSize size,
+                             int fd,
+                             VkMemoryPropertyFlags flags,
+                             struct vn_renderer_bo **out_bo)
+{
+   struct vtest *vtest = (struct vtest *)renderer;
+
+   if (!vtest->has_venus_sync_fd)
+      return VK_ERROR_INVALID_EXTERNAL_HANDLE;
+
+   /* the server dups the fd via SCM_RIGHTS; the caller keeps ownership of
+    * its fd
+    */
+   mtx_lock(&vtest->sock_mutex);
+   const uint32_t res_id = vtest_vcmd_resource_import_blob(vtest, size, fd);
+   mtx_unlock(&vtest->sock_mutex);
+
+   if (!res_id)
+      return VK_ERROR_INVALID_EXTERNAL_HANDLE;
+
+   struct vtest_bo *bo = util_sparse_array_get(&vtest->bo_array, res_id);
+   *bo = (struct vtest_bo){
+      .base = {
+         .refcount = VN_REFCOUNT_INIT(1),
+         .res_id = res_id,
+         .mmap_size = 0, /* not cpu-mappable through this bo */
+      },
+      .res_fd = -1,
+      .blob_flags = VCMD_BLOB_FLAG_SHAREABLE,
+   };
+
+   *out_bo = &bo->base;
+
+   return VK_SUCCESS;
+}
+
 static bool
 vtest_bo_destroy(struct vn_renderer *renderer, struct vn_renderer_bo *_bo)
 {
@@ -951,7 +1040,7 @@ vtest_init_renderer_info(struct vtest *vtest)
    info->pci.vendor_id = VTEST_PCI_VENDOR_ID;
    info->pci.device_id = VTEST_PCI_DEVICE_ID;
 
-   info->has_dma_buf_import = false;
+   info->has_dma_buf_import = vtest->has_venus_sync_fd;
    info->has_external_sync = vtest->has_venus_sync_fd;
    info->has_implicit_fencing = false;
 
@@ -1094,7 +1183,7 @@ vtest_init(struct vtest *vtest)
 
    vtest->base.bo_ops.create_from_device_memory =
       vtest_bo_create_from_device_memory;
-   vtest->base.bo_ops.create_from_dma_buf = NULL;
+   vtest->base.bo_ops.create_from_dma_buf = vtest_bo_create_from_dma_buf;
    vtest->base.bo_ops.destroy = vtest_bo_destroy;
    vtest->base.bo_ops.export_dma_buf = vtest_bo_export_dma_buf;
    vtest->base.bo_ops.export_sync_file =
