From 6893680d88e73f6cecedc69cfb768db57c76ed81 Mon Sep 17 00:00:00 2001
From: forsen <gazikkamalov2@gmail.com>
Date: Fri, 10 Jul 2026 19:23:49 +0300
Subject: [PATCH 1/2] venus/vtest: implement sync_fd export over the vtest
 socket

Query VCMD_PARAM_HAS_VENUS_SYNC_FD; when present, advertise
has_external_sync and implement sync_ops.export_syncobj via
VCMD_SYNC_EXPORT_SYNC_FILE (fd over SCM_RIGHTS; -1 = already signaled).
vn_create_sync_file accepts the -1 already-signaled convention.
---
 android-x86_64-cross.ini              | 14 ++++++
 src/virtio/vtest/vtest_protocol.h     | 16 +++++++
 src/virtio/vulkan/vn_queue.c          |  5 ++-
 src/virtio/vulkan/vn_renderer_vtest.c | 65 ++++++++++++++++++++++++++-
 4 files changed, 97 insertions(+), 3 deletions(-)
 create mode 100644 android-x86_64-cross.ini

diff --git a/android-x86_64-cross.ini b/android-x86_64-cross.ini
new file mode 100644
index 0000000..bf63619
--- /dev/null
+++ b/android-x86_64-cross.ini
@@ -0,0 +1,14 @@
+[binaries]
+ar = '/opt/android-ndk/toolchains/llvm/prebuilt/linux-x86_64/bin/llvm-ar'
+c = ['ccache', '/opt/android-ndk/toolchains/llvm/prebuilt/linux-x86_64/bin/x86_64-linux-android34-clang']
+cpp = ['ccache', '/opt/android-ndk/toolchains/llvm/prebuilt/linux-x86_64/bin/x86_64-linux-android34-clang++', '-fno-exceptions', '-fno-unwind-tables', '-fno-asynchronous-unwind-tables', '-static-libstdc++']
+c_ld = 'lld'
+cpp_ld = 'lld'
+strip = '/opt/android-ndk/toolchains/llvm/prebuilt/linux-x86_64/bin/llvm-strip'
+pkg-config = ['env', 'PKG_CONFIG_LIBDIR=/home/forsen/repos/waydroid-nv/ndk-pkgconfig', '/usr/bin/pkg-config']
+
+[host_machine]
+system = 'android'
+cpu_family = 'x86_64'
+cpu = 'x86_64'
+endian = 'little'
diff --git a/src/virtio/vtest/vtest_protocol.h b/src/virtio/vtest/vtest_protocol.h
index 1bd515c..88ccdd7 100644
--- a/src/virtio/vtest/vtest_protocol.h
+++ b/src/virtio/vtest/vtest_protocol.h
@@ -94,6 +94,9 @@
 #define VCMD_DRM_SYNC_TRANSFER 37
 #define VCMD_RESOURCE_EXPORT_FD 38
 
+/* export a sync_file fd for a pending venus sync point */
+#define VCMD_SYNC_EXPORT_SYNC_FILE 39
+
 #define VCMD_RES_CREATE_SIZE 10
 #define VCMD_RES_CREATE_RES_HANDLE 0 /* must be 0 since protocol version 3 */
 #define VCMD_RES_CREATE_TARGET 1
@@ -163,6 +166,8 @@
 enum vcmd_param  {
    VCMD_PARAM_MAX_TIMELINE_COUNT = 1,
    VCMD_PARAM_HAS_TIMELINE_SYNCOBJ = 2,
+   /* server supports VCMD_SYNC_EXPORT_SYNC_FILE for venus sync points */
+   VCMD_PARAM_HAS_VENUS_SYNC_FD = 3,
 };
 #define VCMD_GET_PARAM_SIZE 1
 #define VCMD_GET_PARAM_PARAM 0
@@ -225,6 +230,17 @@ enum vcmd_sync_wait_flag {
 #define VCMD_SYNC_WAIT_VALUE_HI(n) (2 + 3 * (n) + 2)
 /* resp poll'able fd */
 
+enum vcmd_sync_export_sync_file_status {
+   VCMD_SYNC_EXPORT_SYNC_FILE_OK = 0,
+   VCMD_SYNC_EXPORT_SYNC_FILE_SIGNALED = 1,
+   VCMD_SYNC_EXPORT_SYNC_FILE_ERROR = 2,
+};
+#define VCMD_SYNC_EXPORT_SYNC_FILE_SIZE 3
+#define VCMD_SYNC_EXPORT_SYNC_FILE_ID 0
+#define VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_LO 1
+#define VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_HI 2
+/* resp status dword, then 1 fd if status == OK */
+
 enum vcmd_submit_cmd2_flag {
    VCMD_SUBMIT_CMD2_FLAG_RING_IDX = 1 << 0,
    VCMD_SUBMIT_CMD2_FLAG_IN_FENCE_FD = 1 << 1,
diff --git a/src/virtio/vulkan/vn_queue.c b/src/virtio/vulkan/vn_queue.c
index 0abfb14..4c337a3 100644
--- a/src/virtio/vulkan/vn_queue.c
+++ b/src/virtio/vulkan/vn_queue.c
@@ -1875,7 +1875,10 @@ vn_create_sync_file(struct vn_device *dev,
    *out_fd = vn_renderer_sync_export_syncobj(dev->renderer, sync, true);
    vn_renderer_sync_destroy(dev->renderer, sync);
 
-   return *out_fd >= 0 ? VK_SUCCESS : VK_ERROR_TOO_MANY_OBJECTS;
+   /* -1 is a valid already-signaled sync file (see vn_sync_valid_fd);
+    * transports return < -1 on error
+    */
+   return *out_fd >= -1 ? VK_SUCCESS : VK_ERROR_TOO_MANY_OBJECTS;
 }
 
 static inline bool
diff --git a/src/virtio/vulkan/vn_renderer_vtest.c b/src/virtio/vulkan/vn_renderer_vtest.c
index ecbd373..fb876a0 100644
--- a/src/virtio/vulkan/vn_renderer_vtest.c
+++ b/src/virtio/vulkan/vn_renderer_vtest.c
@@ -56,6 +56,7 @@ struct vtest {
 
    uint32_t protocol_version;
    uint32_t max_timeline_count;
+   bool has_venus_sync_fd;
 
    struct {
       uint32_t id;
@@ -480,6 +481,40 @@ vtest_vcmd_sync_wait(struct vtest *vtest,
    return vtest_receive_fd(vtest);
 }
 
+static int
+vtest_vcmd_sync_export_sync_file(struct vtest *vtest,
+                                 uint32_t sync_id,
+                                 uint64_t value)
+{
+   uint32_t vtest_hdr[VTEST_HDR_SIZE];
+   uint32_t vcmd_export[VCMD_SYNC_EXPORT_SYNC_FILE_SIZE];
+
+   vtest_hdr[VTEST_CMD_LEN] = VCMD_SYNC_EXPORT_SYNC_FILE_SIZE;
+   vtest_hdr[VTEST_CMD_ID] = VCMD_SYNC_EXPORT_SYNC_FILE;
+   vcmd_export[VCMD_SYNC_EXPORT_SYNC_FILE_ID] = sync_id;
+   vcmd_export[VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_LO] = (uint32_t)value;
+   vcmd_export[VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_HI] = (uint32_t)(value >> 32);
+
+   vtest_write(vtest, vtest_hdr, sizeof(vtest_hdr));
+   vtest_write(vtest, vcmd_export, sizeof(vcmd_export));
+
+   vtest_read(vtest, vtest_hdr, sizeof(vtest_hdr));
+   assert(vtest_hdr[VTEST_CMD_ID] == VCMD_SYNC_EXPORT_SYNC_FILE);
+
+   uint32_t status;
+   vtest_read(vtest, &status, sizeof(status));
+
+   switch (status) {
+   case VCMD_SYNC_EXPORT_SYNC_FILE_OK:
+      return vtest_receive_fd(vtest);
+   case VCMD_SYNC_EXPORT_SYNC_FILE_SIGNALED:
+      /* -1 is the conventional already-signaled sync_file */
+      return -1;
+   default:
+      return -EINVAL;
+   }
+}
+
 static void
 vtest_vcmd_submit_cmd2(struct vtest *vtest,
                        const struct vn_renderer_submit_batch *batch)
@@ -572,6 +607,29 @@ vtest_sync_reset(struct vn_renderer *renderer,
    return vtest_sync_write(renderer, sync, initial_val);
 }
 
+static int
+vtest_sync_export_syncobj(struct vn_renderer *renderer,
+                          struct vn_renderer_sync *_sync,
+                          bool sync_file)
+{
+   struct vtest *vtest = (struct vtest *)renderer;
+   struct vtest_sync *sync = (struct vtest_sync *)_sync;
+
+   /* only sync_file fds are useful across the socket */
+   if (!sync_file || !vtest->has_venus_sync_fd)
+      return -ENOTSUP;
+
+   /* Resolve the (binary) sync's signal point to the pending submit's
+    * VkFence on the server and export a sync_file from it.  -1 means the
+    * point already retired (already-signaled sync_file convention).
+    */
+   mtx_lock(&vtest->sock_mutex);
+   const int fd = vtest_vcmd_sync_export_sync_file(vtest, sync->base.sync_id, 1);
+   mtx_unlock(&vtest->sock_mutex);
+
+   return fd;
+}
+
 static void
 vtest_sync_destroy(struct vn_renderer *renderer,
                    struct vn_renderer_sync *_sync)
@@ -894,7 +952,7 @@ vtest_init_renderer_info(struct vtest *vtest)
    info->pci.device_id = VTEST_PCI_DEVICE_ID;
 
    info->has_dma_buf_import = false;
-   info->has_external_sync = false;
+   info->has_external_sync = vtest->has_venus_sync_fd;
    info->has_implicit_fencing = false;
 
    const struct virgl_renderer_capset_venus *capset = &vtest->capset.data;
@@ -964,6 +1022,9 @@ vtest_init_params(struct vtest *vtest)
    }
    vtest->max_timeline_count = val;
 
+   vtest->has_venus_sync_fd =
+      vtest_vcmd_get_param(vtest, VCMD_PARAM_HAS_VENUS_SYNC_FD);
+
    return VK_SUCCESS;
 }
 
@@ -1045,7 +1106,7 @@ vtest_init(struct vtest *vtest)
    vtest->base.sync_ops.create = vtest_sync_create;
    vtest->base.sync_ops.create_from_syncobj = NULL;
    vtest->base.sync_ops.destroy = vtest_sync_destroy;
-   vtest->base.sync_ops.export_syncobj = NULL;
+   vtest->base.sync_ops.export_syncobj = vtest_sync_export_syncobj;
    vtest->base.sync_ops.reset = vtest_sync_reset;
    vtest->base.sync_ops.read = vtest_sync_read;
    vtest->base.sync_ops.write = vtest_sync_write;
-- 
