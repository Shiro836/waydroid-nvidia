+          !(cur->propertyFlags & VK_MEMORY_PROPERTY_HOST_CACHED_BIT)) {
+         for (uint32_t i = 0; i < props->memoryTypeCount; i++) {
+            const VkMemoryType *cand = &props->memoryTypes[i];
+            if (cand->heapIndex == cur->heapIndex &&
+                (cand->propertyFlags &
+                 (cur->propertyFlags | VK_MEMORY_PROPERTY_HOST_CACHED_BIT)) ==
+                   (cur->propertyFlags | VK_MEMORY_PROPERTY_HOST_CACHED_BIT)) {
+               steered_info = *pAllocateInfo;
+               steered_info.memoryTypeIndex = i;
+               pAllocateInfo = &steered_info;
+               break;
+            }
+         }
+      }
