+/* Cache of dma_buf memoryTypeBits keyed by the dma_buf's inode.  Each
+ * uncached vn_get_memory_dma_buf_properties costs three renderer roundtrips
+ * (bo import, ring roundtrip, ring call) and Android re-queries the same
+ * gralloc buffers every frame (AHB wrapping in ANGLE/HWUI).  dma_buf inode
+ * numbers come from a monotonic counter and are never reused, and a given
+ * buffer's memoryTypeBits are immutable, so cache hits are always sound.
+ */
+#define VN_DMA_BUF_PROPS_CACHE_SIZE 64
+struct vn_dma_buf_props_cache {
+   simple_mtx_t mutex;
+   struct {
+      uint64_t ino;
+      uint32_t mem_type_bits;
+   } entries[VN_DMA_BUF_PROPS_CACHE_SIZE];
+   uint32_t count; /* valid entries */
+   uint32_t next;  /* round-robin replacement cursor */
+};
+
