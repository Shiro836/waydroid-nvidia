diff --git a/src/venus/vkr_queue.c b/src/venus/vkr_queue.c
index 61b94be..b7242e0 100644
--- a/src/venus/vkr_queue.c
+++ b/src/venus/vkr_queue.c
@@ -111,6 +111,56 @@ vkr_queue_sync_submit(struct vkr_queue *queue,
    return true;
 }
 
+
+int
+vkr_queue_export_fence_sync_file(struct vkr_queue *queue, uint64_t fence_id, int *out_fd)
+{
+   TRACE_FUNC();
+   struct vkr_device *dev = queue->device;
+   struct vn_device_proc_table *vk = &dev->proc_table;
+
+   if (!dev->physical_device->KHR_external_fence_fd)
+      return -ENOTSUP;
+
+   int ret = 1;
+   mtx_lock(&queue->sync_thread.mutex);
+   list_for_each_entry (struct vkr_queue_sync, sync, &queue->sync_thread.syncs, head) {
+      if (sync->fence_id != fence_id)
+         continue;
+
+      if (sync->device_lost) {
+         ret = -ENODEV;
+         break;
+      }
+
+      /* SYNC_FD export has copy transference and the fence has a pending
+       * signal operation (QueueSubmit happened in vkr_queue_sync_submit), so
+       * this is spec-legal even while the sync thread waits on the fence.
+       * The driver may return -1 if the fence already signaled; map that to
+       * "already signaled".
+       */
+      const VkFenceGetFdInfoKHR info = {
+         .sType = VK_STRUCTURE_TYPE_FENCE_GET_FD_INFO_KHR,
+         .fence = sync->fence,
+         .handleType = VK_EXTERNAL_FENCE_HANDLE_TYPE_SYNC_FD_BIT,
+      };
+      int fd = -1;
+      VkResult result = vk->GetFenceFdKHR(dev->base.handle.device, &info, &fd);
+      if (result != VK_SUCCESS) {
+         ret = -EINVAL;
+      } else if (fd < 0) {
+         ret = 1;
+      } else {
+         *out_fd = fd;
+         ret = 0;
+      }
+      break;
+   }
+   mtx_unlock(&queue->sync_thread.mutex);
+
+   return ret;
+}
+
 static void
 vkr_queue_sync_thread_fini(struct vkr_queue *queue)
 {
