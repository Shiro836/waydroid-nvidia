diff --git a/server/render_context.c b/server/render_context.c
index b44b5b5..718b1b5 100644
--- a/server/render_context.c
+++ b/server/render_context.c
@@ -23,6 +23,34 @@ render_context_update_timeline(struct render_context *ctx,
       write_eventfd(ctx->fence_eventfd, 1);
 }
 
+static bool
+render_context_dispatch_export_fence(struct render_context *ctx,
+                                     const union render_context_op_request *request,
+                                     UNUSED const int *fds,
+                                     UNUSED int fd_count)
+{
+   const struct render_context_op_export_fence_request *req = &request->export_fence;
+   struct render_context_op_export_fence_reply reply = {
+      .status = RENDER_CONTEXT_EXPORT_FENCE_ERROR,
+   };
+
+   int fd = -1;
+   const int ret =
+      render_state_export_fence(ctx->ctx_id, req->ring_index, req->seqno, &fd);
+   if (ret == 0) {
+      reply.status = RENDER_CONTEXT_EXPORT_FENCE_OK;
+      const bool ok =
+         render_socket_send_reply_with_fds(&ctx->socket, &reply, sizeof(reply), &fd, 1);
+      close(fd);
+      return ok;
+   }
+
+   if (ret == 1)
+      reply.status = RENDER_CONTEXT_EXPORT_FENCE_SIGNALED;
+
+   return render_socket_send_reply(&ctx->socket, &reply, sizeof(reply));
+}
