+int
+vkr_context_export_fence(struct vkr_context *ctx,
+                         uint32_t ring_idx,
+                         uint64_t fence_id,
+                         int *out_fd)
+{
+   /* ring 0 is the cpu timeline: fences retire at submit time */
+   if (ring_idx == 0)
+      return 1;
+
+   if (ring_idx >= ARRAY_SIZE(ctx->sync_queues) || !ctx->sync_queues[ring_idx]) {
+      vkr_log("export_fence: invalid ring_idx %u", ring_idx);
+      return -EINVAL;
+   }
+
+   return vkr_queue_export_fence_sync_file(ctx->sync_queues[ring_idx], fence_id, out_fd);
+}
