+/* Export a sync_file fd for a previously submitted, not-yet-retired fence.
+ *
+ * The fence is identified by (ring_index, seqno) as used by
+ * RENDER_CONTEXT_OP_SUBMIT_FENCE.  The reply carries a status; when the
+ * status is RENDER_CONTEXT_EXPORT_FENCE_OK the reply is followed by 1 fd (a
+ * kernel sync_file exported from the fence's VkFence).
+ * RENDER_CONTEXT_EXPORT_FENCE_SIGNALED means the fence already retired or
+ * the driver reported it signaled (no fd follows; treat as an
+ * already-signaled sync_file).
+ */
+enum render_context_export_fence_status {
+   RENDER_CONTEXT_EXPORT_FENCE_OK = 0,
+   RENDER_CONTEXT_EXPORT_FENCE_SIGNALED = 1,
+   RENDER_CONTEXT_EXPORT_FENCE_ERROR = 2,
+};
+
+struct render_context_op_export_fence_request {
+   struct render_context_op_header header;
+   uint32_t ring_index;
+   uint32_t seqno;
+};
+
+struct render_context_op_export_fence_reply {
+   uint32_t status; /* enum render_context_export_fence_status */
+   /* followed by 1 fd if status == RENDER_CONTEXT_EXPORT_FENCE_OK */
+};
