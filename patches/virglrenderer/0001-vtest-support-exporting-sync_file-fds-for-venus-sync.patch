diff --git a/src/proxy/proxy_context.c b/src/proxy/proxy_context.c
index 2780a54..801517d 100644
--- a/src/proxy/proxy_context.c
+++ b/src/proxy/proxy_context.c
@@ -194,6 +194,79 @@ proxy_context_sync_thread(void *arg)
    return 0;
 }
 
+static int
+proxy_context_export_fence(struct virgl_context *base,
+                           uint32_t ring_idx,
+                           uint64_t fence_id,
+                           int *out_fd)
+{
+   struct proxy_context *ctx = (struct proxy_context *)base;
+
+   if (ring_idx >= PROXY_CONTEXT_TIMELINE_COUNT)
+      return -EINVAL;
+
+   /* translate fence_id to the render-server seqno of the pending fence; if
+    * it is no longer pending it has retired -> already signaled
+    */
+   struct proxy_timeline *timeline = &ctx->timelines[ring_idx];
+   bool found = false;
+   uint32_t seqno = 0;
+
+   if (proxy_renderer.flags & VIRGL_RENDERER_ASYNC_FENCE_CB)
+      mtx_lock(&ctx->timeline_mutex);
+
+   list_for_each_entry (struct proxy_fence, fence, &timeline->fences, head) {
+      if (fence->fence_id == fence_id) {
+         seqno = fence->seqno;
+         found = true;
+         break;
+      }
+   }
+
+   if (proxy_renderer.flags & VIRGL_RENDERER_ASYNC_FENCE_CB)
+      mtx_unlock(&ctx->timeline_mutex);
+
+   if (!found)
+      return 1;
+
+   const struct render_context_op_export_fence_request req = {
+      .header.op = RENDER_CONTEXT_OP_EXPORT_FENCE,
+      .ring_index = ring_idx,
+      .seqno = seqno,
+   };
+   if (!proxy_socket_send_request(&ctx->socket, &req, sizeof(req))) {
+      proxy_log("failed to send export_fence");
+      return -ENOTCONN;
+   }
+
+   struct render_context_op_export_fence_reply reply;
+   int reply_fd = -1;
+   int reply_fd_count = 0;
+   if (!proxy_socket_receive_reply_with_fds(&ctx->socket, &reply, sizeof(reply),
+                                            &reply_fd, 1, &reply_fd_count)) {
+      proxy_log("failed to get export_fence reply");
+      return -ENOTCONN;
+   }
+
+   switch (reply.status) {
+   case RENDER_CONTEXT_EXPORT_FENCE_OK:
+      if (!reply_fd_count) {
+         proxy_log("export_fence reply missing fd");
+         return -EINVAL;
+      }
+      *out_fd = reply_fd;
+      return 0;
+   case RENDER_CONTEXT_EXPORT_FENCE_SIGNALED:
+      if (reply_fd_count)
+         close(reply_fd);
+      return 1;
+   default:
+      if (reply_fd_count)
+         close(reply_fd);
+      return -EINVAL;
+   }
+}
+
 static int
 proxy_context_submit_fence(struct virgl_context *base,
                            uint32_t flags,
@@ -563,6 +636,7 @@ proxy_context_init_base(struct proxy_context *ctx)
