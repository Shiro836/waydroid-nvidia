+   struct vtest_context *ctx = vtest_get_current_context();
+   uint32_t export_buf[VCMD_SYNC_EXPORT_SYNC_FILE_SIZE];
+   uint32_t resp_buf[VTEST_HDR_SIZE + 1];
+   uint32_t status = VCMD_SYNC_EXPORT_SYNC_FILE_ERROR;
+   struct vtest_sync *sync;
+   int fd = -1;
+   int ret;
+
+   if (length_dw != VCMD_SYNC_EXPORT_SYNC_FILE_SIZE)
+      return -EINVAL;
+
+   ret = ctx->input->read(ctx->input, export_buf, sizeof(export_buf));
+   if (ret != sizeof(export_buf))
+      return -1;
+
+   const uint32_t sync_id = export_buf[VCMD_SYNC_EXPORT_SYNC_FILE_ID];
+   const uint64_t value = export_buf[VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_LO] |
+                          (uint64_t)export_buf[VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_HI] << 32;
+
+   sync = util_hash_table_get(ctx->sync_table, intptr_to_pointer(sync_id));
+   if (sync) {
+      /* find the newest pending timeline submit that will signal this sync
+       * to at least the requested value; if there is none, the sync point
+       * has already retired
+       */
+      struct vtest_timeline_submit *found = NULL;
+      uint32_t found_ring = 0;
+
+      for (uint32_t ring = 0; ring < VTEST_MAX_TIMELINE_COUNT; ring++) {
+         struct vtest_timeline *timeline = &ctx->timelines[ring];
+         list_for_each_entry (struct vtest_timeline_submit, submit,
+                              &timeline->submits, head) {
+            for (uint32_t j = 0; j < submit->count; j++) {
+               if (submit->syncs[j] == sync && submit->values[j] >= value) {
+                  found = submit;
+                  found_ring = ring;
+                  break;
+               }
+            }
+         }
+      }
+
+      if (found) {
+         ret = virgl_renderer_context_export_fence(ctx->ctx_id, found_ring,
+                                                   (uintptr_t)found, &fd);
+         if (ret == 0 && fd >= 0)
+            status = VCMD_SYNC_EXPORT_SYNC_FILE_OK;
+         else if (ret == 1)
+            status = VCMD_SYNC_EXPORT_SYNC_FILE_SIGNALED;
+      } else {
+         status = VCMD_SYNC_EXPORT_SYNC_FILE_SIGNALED;
+      }
+   }
+
+   resp_buf[VTEST_CMD_LEN] = 1;
+   resp_buf[VTEST_CMD_ID] = VCMD_SYNC_EXPORT_SYNC_FILE;
+   resp_buf[VTEST_CMD_DATA_START] = status;
+   ret = vtest_block_write(ctx->out_fd, resp_buf, sizeof(resp_buf));
+   if (ret >= 0 && status == VCMD_SYNC_EXPORT_SYNC_FILE_OK)
+      ret = vtest_send_fd(ctx->out_fd, fd);
+
+   if (fd >= 0)
+      close(fd);
+
+   return ret >= 0 ? 0 : ret;
+}
