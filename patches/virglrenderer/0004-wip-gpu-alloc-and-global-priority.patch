+static int64_t
+vkr_timeline_now_ns(void)
+{
+   struct timespec ts;
+   clock_gettime(CLOCK_MONOTONIC, &ts);
+   return (int64_t)ts.tv_sec * 1000000000 + ts.tv_nsec;
+}
+
+/* Perform one sync_file -> timeline-point import.  Runs on the timeline
+ * worker (or inline if the worker failed to start); ctx->timeline handles
+ * are immutable once created, so no lock is needed here.
+ */
+static void
+vkr_context_timeline_import_one(struct vkr_context *ctx,
+                                int sync_file_fd,
+                                uint64_t timeline_point)
+{
+   const int drm_fd = ctx->timeline.drm_fd;
+   bool imported = false;
+
+   const int64_t t0 = vkr_timeline_now_ns();
+   int64_t t_ioctl = t0, t_close = t0;
+
+   if (sync_file_fd >= 0 && ctx->timeline.one_ioctl) {
+      /* one-ioctl chain-add (kernel >= 6.16): no fence replacement happens,
+       * so no prior NVIDIA fence is released synchronously in the ioctl;
+       * waiters wake on the new point before the chain GC walk runs
+       */
+      struct drm_syncobj_handle import = {
+         .handle = ctx->timeline.handle,
+         .flags = DRM_SYNCOBJ_FD_TO_HANDLE_FLAGS_IMPORT_SYNC_FILE |
+                  DRM_SYNCOBJ_FD_TO_HANDLE_FLAGS_TIMELINE,
+         .fd = sync_file_fd,
+         .point = timeline_point,
+      };
+      if (!ioctl(drm_fd, DRM_IOCTL_SYNCOBJ_FD_TO_HANDLE, &import)) {
+         imported = true;
+      } else if (errno == EINVAL) {
+         vkr_log("timeline: no one-ioctl timeline import (pre-6.16 kernel), "
+                 "using scratch-syncobj fallback");
+         ctx->timeline.one_ioctl = false;
+      }
+   }
+
+   if (sync_file_fd >= 0 && !imported && !ctx->timeline.one_ioctl) {
+      /* two-step fallback via the persistent scratch binary syncobj:
+       * IMPORT_SYNC_FILE replaces its fence, then transfer to the point
+       */
+      struct drm_syncobj_handle import = {
+         .handle = ctx->timeline.scratch,
+         .flags = DRM_SYNCOBJ_FD_TO_HANDLE_FLAGS_IMPORT_SYNC_FILE,
+         .fd = sync_file_fd,
+      };
+      struct drm_syncobj_transfer xfer = {
+         .src_handle = ctx->timeline.scratch,
+         .dst_handle = ctx->timeline.handle,
+         .dst_point = timeline_point,
+      };
+      imported = !ioctl(drm_fd, DRM_IOCTL_SYNCOBJ_FD_TO_HANDLE, &import) &&
+                 !ioctl(drm_fd, DRM_IOCTL_SYNCOBJ_TRANSFER, &xfer);
+   }
+
+   if (!imported) {
+      /* fd < 0 = fence already signaled; also the failure fallback so the
+       * client never stalls on WAIT_AVAILABLE
+       */
+      if (sync_file_fd >= 0)
+         vkr_log("timeline: import at point %" PRIu64 " failed, signaling",
+                 timeline_point);
+      const uint64_t point = timeline_point;
+      const uint32_t handle = ctx->timeline.handle;
+      struct drm_syncobj_timeline_array signal = {
+         .handles = (uintptr_t)&handle,
+         .points = (uintptr_t)&point,
+         .count_handles = 1,
+      };
+      ioctl(drm_fd, DRM_IOCTL_SYNCOBJ_TIMELINE_SIGNAL, &signal);
+   }
+
+   t_ioctl = vkr_timeline_now_ns();
+   if (sync_file_fd >= 0)
+      close(sync_file_fd);
+   t_close = vkr_timeline_now_ns();
+
+   if (t_close - t0 > 2000000)
+      vkr_log("NVWD-TL slow import point %" PRIu64 ": ioctls %" PRId64
+              " us close %" PRId64 " us (%s)",
+              timeline_point, (t_ioctl - t0) / 1000, (t_close - t_ioctl) / 1000,
+              ctx->timeline.one_ioctl ? "one-ioctl" : "scratch");
+}
+
+static int
+vkr_context_timeline_worker(void *arg)
+{
+   struct vkr_context *ctx = arg;
+
+   mtx_lock(&ctx->timeline.mutex);
+   while (true) {
+      while (!ctx->timeline.worker.count && !ctx->timeline.worker.join)
+         cnd_wait(&ctx->timeline.worker.cond, &ctx->timeline.mutex);
+
+      struct {
+         int fd;
+         uint64_t point;
+      } jobs[ARRAY_SIZE(ctx->timeline.worker.jobs)];
+      const uint32_t count = ctx->timeline.worker.count;
+      memcpy(jobs, ctx->timeline.worker.jobs, sizeof(jobs[0]) * count);
+      ctx->timeline.worker.count = 0;
+      const bool join = ctx->timeline.worker.join;
+      cnd_broadcast(&ctx->timeline.worker.space);
+      mtx_unlock(&ctx->timeline.mutex);
+
+      for (uint32_t i = 0; i < count; i++)
+         vkr_context_timeline_import_one(ctx, jobs[i].fd, jobs[i].point);
+
+      if (join)
+         return 0;
+      mtx_lock(&ctx->timeline.mutex);
+   }
+}
+
+/* Any render node works: syncobjs are containers for driver-agnostic
+ * dma_fences and all syncobj ioctls are DRM_RENDER_ALLOW.  drm_fd == -2
+ * marks a failed earlier attempt.
+ */
+static bool
+vkr_context_timeline_ensure_locked(struct vkr_context *ctx)
+{
+   if (ctx->timeline.handle)
+      return true;
+   if (ctx->timeline.drm_fd == -2)
+      return false;
+
+   for (int minor = 128; minor < 128 + 16; minor++) {
+      char path[64];
+      snprintf(path, sizeof(path), "/dev/dri/renderD%d", minor);
+      int fd = open(path, O_RDWR | O_CLOEXEC);
+      if (fd < 0)
+         continue;
+      snprintf(ctx->timeline.node_path, sizeof(ctx->timeline.node_path), "%s", path);
+
+      struct drm_get_cap cap = { .capability = DRM_CAP_SYNCOBJ_TIMELINE };
+      struct drm_syncobj_create create = { 0 };
+      struct drm_syncobj_create scratch = { 0 };
+      if (ioctl(fd, DRM_IOCTL_GET_CAP, &cap) || !cap.value ||
+          ioctl(fd, DRM_IOCTL_SYNCOBJ_CREATE, &create) ||
+          ioctl(fd, DRM_IOCTL_SYNCOBJ_CREATE, &scratch)) {
+         close(fd);
+         continue;
+      }
+
+      ctx->timeline.drm_fd = fd;
+      ctx->timeline.handle = create.handle;
+      ctx->timeline.scratch = scratch.handle;
+      ctx->timeline.one_ioctl = true;
+
+      if (cnd_init(&ctx->timeline.worker.cond) == thrd_success) {
+         if (cnd_init(&ctx->timeline.worker.space) == thrd_success) {
+            if (thrd_create(&ctx->timeline.worker.thread,
+                            vkr_context_timeline_worker, ctx) == thrd_success) {
+               ctx->timeline.worker.started = true;
+            } else {
+               cnd_destroy(&ctx->timeline.worker.space);
+               cnd_destroy(&ctx->timeline.worker.cond);
+            }
+         } else {
+            cnd_destroy(&ctx->timeline.worker.cond);
+         }
+      }
+      return true;
+   }
+
+   vkr_log("timeline: no syncobj-timeline-capable render node found");
+   ctx->timeline.drm_fd = -2;
+   return false;
+}
