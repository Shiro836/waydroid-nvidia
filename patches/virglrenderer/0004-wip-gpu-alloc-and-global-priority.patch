+int
+vkr_context_get_timeline_fd(struct vkr_context *ctx,
+                            int *out_syncobj_fd,
+                            int *out_node_fd)
+{
+   mtx_lock(&ctx->timeline.mutex);
+   if (!vkr_context_timeline_ensure_locked(ctx)) {
+      mtx_unlock(&ctx->timeline.mutex);
+      return -ENODEV;
+   }
+
+   /* the client also gets a render-node fd so it can perform syncobj ioctls
+    * without needing (or having permissions on) a /dev/dri node of its own —
+    * fd passing sidesteps path access entirely.
+    *
+    * This must be a FRESH open, not a dup of our fd: a dup shares the
+    * struct file (and thus the drm_file), and DRM core's
+    * drm_file_update_pid() runs mutex + synchronize_rcu (~10 ms under load)
+    * on EVERY ioctl whose caller tgid differs from the previous one — two
+    * processes alternating ioctls on one drm_file poisons both.  With a
+    * fresh file the client is its sole user after a single handover.
+    */
