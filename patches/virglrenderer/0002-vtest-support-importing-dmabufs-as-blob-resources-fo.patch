From e8a33ed6a4489fed52d1f15300f83af5b80694d8 Mon Sep 17 00:00:00 2001
From: forsen <gazikkamalov2@gmail.com>
Date: Fri, 10 Jul 2026 20:06:20 +0300
Subject: [PATCH 2/3] vtest: support importing dmabufs as blob resources for
 venus

New VCMD_RESOURCE_IMPORT_BLOB: receives a dmabuf fd over SCM_RIGHTS,
registers it via virgl_renderer_resource_import_blob (which takes fd
ownership) and attaches it to the context. Size 0 derives the size from
the dmabuf via lseek (venus queries memory properties with size 0).
proxy: ring-0 export_fence now performs a wire round trip, used as an
ordering barrier so the import is visible to the venus ring before the
client learns the res_id.
---
 src/proxy/proxy_context.c | 23 ++++++++++++
 vtest/vtest.h             |  1 +
 vtest/vtest_protocol.h    | 12 ++++++
 vtest/vtest_renderer.c    | 78 +++++++++++++++++++++++++++++++++++++++
 vtest/vtest_server.c      |  1 +
 5 files changed, 115 insertions(+)

diff --git a/src/proxy/proxy_context.c b/src/proxy/proxy_context.c
index 801517d..b718ef2 100644
--- a/src/proxy/proxy_context.c
+++ b/src/proxy/proxy_context.c
@@ -205,6 +205,29 @@ proxy_context_export_fence(struct virgl_context *base,
    if (ring_idx >= PROXY_CONTEXT_TIMELINE_COUNT)
       return -EINVAL;
 
+   /* ring 0 is the cpu timeline; used as a synchronous round-trip barrier
+    * (guarantees previously sent context ops have been processed)
+    */
+   if (ring_idx == 0) {
+      const struct render_context_op_export_fence_request req = {
+         .header.op = RENDER_CONTEXT_OP_EXPORT_FENCE,
+         .ring_index = 0,
+         .seqno = 0,
+      };
+      if (!proxy_socket_send_request(&ctx->socket, &req, sizeof(req)))
+         return -ENOTCONN;
+
+      struct render_context_op_export_fence_reply reply;
+      int reply_fd = -1;
+      int reply_fd_count = 0;
+      if (!proxy_socket_receive_reply_with_fds(&ctx->socket, &reply, sizeof(reply),
+                                               &reply_fd, 1, &reply_fd_count))
+         return -ENOTCONN;
+      if (reply_fd_count)
+         close(reply_fd);
+      return 1;
+   }
+
    /* translate fence_id to the render-server seqno of the pending fence; if
     * it is no longer pending it has retired -> already signaled
     */
diff --git a/vtest/vtest.h b/vtest/vtest.h
index ea3b9bb..fa74075 100644
--- a/vtest/vtest.h
+++ b/vtest/vtest.h
@@ -95,6 +95,7 @@ int vtest_sync_read(uint32_t length_dw);
 int vtest_sync_write(uint32_t length_dw);
 int vtest_sync_wait(uint32_t length_dw);
 int vtest_sync_export_sync_file(uint32_t length_dw);
+int vtest_resource_import_blob(uint32_t length_dw);
 
 int vtest_submit_cmd2(uint32_t length_dw);
 
diff --git a/vtest/vtest_protocol.h b/vtest/vtest_protocol.h
index 7453e1b..3a7381f 100644
--- a/vtest/vtest_protocol.h
+++ b/vtest/vtest_protocol.h
@@ -96,6 +96,8 @@
 
 /* export a sync_file fd for a pending venus sync point */
 #define VCMD_SYNC_EXPORT_SYNC_FILE 39
+/* import a dmabuf fd as a blob resource attached to the context */
+#define VCMD_RESOURCE_IMPORT_BLOB 40
 
 #define VCMD_RES_CREATE_SIZE 10
 #define VCMD_RES_CREATE_RES_HANDLE 0 /* must be 0 since protocol version 3 */
@@ -250,6 +252,16 @@ enum vcmd_sync_export_sync_file_status {
 #define VCMD_SYNC_EXPORT_SYNC_FILE_VALUE_HI 2
 /* resp status dword, then 1 fd if status == OK */
 
+/* Import a client-provided dmabuf as a HOST3D blob resource attached to the
+ * current context.  Requires VCMD_PARAM_HAS_VENUS_SYNC_FD.  The request is
+ * followed by 1 fd (SCM_RIGHTS, client -> server).  The response carries the
+ * new res_id, or 0 on failure.
+ */
+#define VCMD_RESOURCE_IMPORT_BLOB_SIZE 2
+#define VCMD_RESOURCE_IMPORT_BLOB_SIZE_LO 0
+#define VCMD_RESOURCE_IMPORT_BLOB_SIZE_HI 1
+/* followed by 1 fd; resp res_id (0 = failure) */
+
 enum vcmd_submit_cmd2_flag {
    VCMD_SUBMIT_CMD2_FLAG_RING_IDX = 1 << 0,
    VCMD_SUBMIT_CMD2_FLAG_IN_FENCE_FD = 1 << 1,
diff --git a/vtest/vtest_renderer.c b/vtest/vtest_renderer.c
index 69b9658..f3212ad 100644
--- a/vtest/vtest_renderer.c
+++ b/vtest/vtest_renderer.c
@@ -2413,6 +2413,84 @@ out:
    return ret;
 }
 
+int vtest_resource_import_blob(uint32_t length_dw)
+{
+   struct vtest_context *ctx = vtest_get_current_context();
+   uint32_t import_buf[VCMD_RESOURCE_IMPORT_BLOB_SIZE];
+   uint32_t resp_buf[VTEST_HDR_SIZE + 1];
+   struct vtest_resource *res = NULL;
+   uint32_t res_id = 0;
+   int ret;
+
+   if (length_dw != VCMD_RESOURCE_IMPORT_BLOB_SIZE)
+      return -EINVAL;
+
+   ret = ctx->input->read(ctx->input, import_buf, sizeof(import_buf));
+   if (ret != sizeof(import_buf))
+      return -1;
+
+   uint64_t size = import_buf[VCMD_RESOURCE_IMPORT_BLOB_SIZE_LO] |
+                   (uint64_t)import_buf[VCMD_RESOURCE_IMPORT_BLOB_SIZE_HI] << 32;
+
+   int fd = vtest_receive_fd(ctx->input->data.fd);
+   if (fd < 0)
+      return report_failed_call("vtest_receive_fd", fd);
+
+   /* venus imports with size 0 when only querying memory properties (see
+    * vn_get_memory_dma_buf_properties); derive the size from the dmabuf
+    */
+   if (!size) {
+      const off_t seek_size = lseek(fd, 0, SEEK_END);
+      if (seek_size < 0) {
+         close(fd);
+         return report_failed_call("lseek", -errno);
+      }
+      size = (uint64_t)seek_size;
+   }
+
+   res = vtest_new_resource(0);
+   if (!res) {
+      close(fd);
+      return -ENOMEM;
+   }
+
+   const struct virgl_renderer_resource_import_blob_args args = {
+      .res_handle = res->res_id,
+      .blob_mem = VIRGL_RENDERER_BLOB_MEM_HOST3D,
+      .fd_type = VIRGL_RENDERER_BLOB_FD_TYPE_DMABUF,
+      .fd = fd,
+      .size = size,
+   };
+   /* on success the fd is owned by the created virgl_resource */
+   ret = virgl_renderer_resource_import_blob(&args);
+   if (ret) {
+      close(fd);
+      vtest_unref_resource(res);
+      report_failed_call("virgl_renderer_resource_import_blob", ret);
+   } else {
+      virgl_renderer_ctx_attach_resource(ctx->ctx_id, res->res_id);
+
+      /* The attach travels the render-server socket while venus ring
+       * commands referencing the new res_id are consumed by a different
+       * thread; force a synchronous round trip on the same socket so the
+       * import is fully processed before the client learns the res_id.
+       * export_fence with ring 0 is a harmless request/reply op.
+       */
+      int barrier_fd = -1;
+      virgl_renderer_context_export_fence(ctx->ctx_id, 0, 0, &barrier_fd);
+      if (barrier_fd >= 0)
+         close(barrier_fd);
+
+      util_hash_table_set(ctx->resource_table, intptr_to_pointer(res->res_id), res);
+      res_id = res->res_id;
+   }
+
+   resp_buf[VTEST_CMD_LEN] = 1;
+   resp_buf[VTEST_CMD_ID] = VCMD_RESOURCE_IMPORT_BLOB;
+   resp_buf[VTEST_CMD_DATA_START] = res_id;
+   return vtest_block_write(ctx->out_fd, resp_buf, sizeof(resp_buf)) >= 0 ? 0 : -1;
+}
+
 int vtest_sync_export_sync_file(uint32_t length_dw)
 {
    struct vtest_context *ctx = vtest_get_current_context();
diff --git a/vtest/vtest_server.c b/vtest/vtest_server.c
index 0d11ec8..8685d33 100644
--- a/vtest/vtest_server.c
+++ b/vtest/vtest_server.c
@@ -731,6 +731,7 @@ static const struct vtest_command {
 #endif /* ENABLE_DRM */
    HANDLER(RESOURCE_EXPORT_FD,          resource_export_fd,        true   ),
    HANDLER(SYNC_EXPORT_SYNC_FILE,       sync_export_sync_file,     true   ),
+   HANDLER(RESOURCE_IMPORT_BLOB,        resource_import_blob,      true   ),
 };
 
 static int vtest_client_dispatch_commands(struct vtest_client *client)
