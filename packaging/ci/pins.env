# Pinned upstreams for clean-room CI builds (full SHAs of patches/*/BASE).
# Single source of truth for .github/workflows/build.yml. Keep in sync with
# patches/*/BASE and dev/env.sh anchors (short forms of the same commits).
NDK_VERSION=r29
# sha256 of android-ndk-r29-linux.zip; filled in after first CI run printed it
NDK_ZIP_SHA256=
