VIRGL_UPSTREAM=https://gitlab.freedesktop.org/virgl/virglrenderer.git
VIRGL_SHA=dc35e4db03144f81637c5ad061f61d3334b078fe
MINIGBM_UPSTREAM=https://github.com/waydroid/android_external_minigbm.git
MINIGBM_SHA=16844babfbd83d7c206ca22256257cbf26ca7de1
WAYDROID_UPSTREAM=https://github.com/waydroid/waydroid.git
