IMG_VENDOR_SHA256=cba35433ffca73ed349e096b1daec495b3204e01c0e541c4203671e6d648e874
LIBDRM_VERSION=2.4.133
LIBDRM_URL=https://dri.freedesktop.org/libdrm/libdrm-2.4.133.tar.xz

