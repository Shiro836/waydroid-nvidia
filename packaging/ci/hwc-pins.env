SYSTEM_LOGGING_SHA=373d54e772f303c441faf2e584a2edf3601b4181

# Static guest-side deps, cross-built for bionic with the pinned NDK
LIBFFI_VERSION=3.4.6
WAYLAND_VERSION=1.25.0
XKBCOMMON_VERSION=1.7.0
LIBFFI_URL=https://github.com/libffi/libffi/releases/download/v3.4.6/libffi-3.4.6.tar.gz
