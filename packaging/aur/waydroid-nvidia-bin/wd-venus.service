[Unit]
Description=Venus vtest render server for waydroid-nvidia

[Service]
Environment=RENDER_SERVER_EXEC_PATH=/usr/lib/waydroid-nvidia/virgl_render_server
Environment=LD_LIBRARY_PATH=/usr/lib/waydroid-nvidia
ExecStart=/usr/lib/waydroid-nvidia/virgl_test_server --venus --multi-clients --socket-path /run/waydroid-venus/venus.sock
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
