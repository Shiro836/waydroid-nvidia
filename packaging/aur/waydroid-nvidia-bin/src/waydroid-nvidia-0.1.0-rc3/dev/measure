#!/usr/bin/env bash
# measure — the canonical smoothness bench: fling the app DRAWER (local,
# deterministic content — horizontal workspace swipes land on the Discover
# news feed, whose network content varies run-to-run) and read HWUI frame
# stats. Numbers go in STATE.md's Log. Requires a booted stack.
#
# Two metric sets:
#  - histogram percentiles (dumpsys gfxinfo): intended-vsync -> present
#    latency, quantized to the vsync grid. At 250 Hz every on-time frame
#    reports exactly one period (5 ms bucket) — it's a pacing check, not a
#    work measurement. Its floor is the refresh period.
#  - framestats (real work): IntendedVsync -> FrameCompleted per frame,
#    nanosecond precision. This is the latency number the DoD means.
# Usage: dev/measure            (app-drawer fling, 5 up/down swipe pairs)
#        dev/measure <pkg>      (bench a specific package instead)
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo

PKG="${1:-com.android.launcher3}"
OUT="$(mktemp)"
trap 'rm -f "$OUT"' EXIT

say "fling bench: $PKG (wake, home, open app drawer, 5x vertical fling)"
guest "
  input keyevent KEYCODE_WAKEUP; input keyevent KEYCODE_MENU; sleep 1
  input keyevent KEYCODE_HOME; sleep 1
  input swipe 1280 1200 1280 300 150; sleep 1
  input swipe 1280 1100 1280 340 100; sleep 0.5
  input swipe 1280 340 1280 1100 100; sleep 0.5
  dumpsys gfxinfo $PKG reset >/dev/null
  for i in 1 2 3 4 5; do
    input swipe 1280 1100 1280 340 100; sleep 0.5
    input swipe 1280 340 1280 1100 100; sleep 0.5
  done
  dumpsys gfxinfo $PKG framestats
  input keyevent KEYCODE_HOME
" > "$OUT"

grep -E 'Total frames|Janky frames|50th|90th|95th|99th' "$OUT"
echo
echo "-- real frame work (framestats, IntendedVsync -> FrameCompleted) --"
python3 - "$OUT" <<'EOF'
import re, sys
lines = open(sys.argv[1]).read().splitlines()
hdr, rows, inblock = None, [], False
for l in lines:
    if l.startswith('---PROFILEDATA---'):
        inblock = not inblock; continue
    if inblock:
        if l.startswith('Flags'): hdr = l.split(',')
        elif re.match(r'^\d', l): rows.append(l.split(','))
if not hdr:
    print("no framestats block"); sys.exit(0)
idx = {n.strip(): i for i, n in enumerate(hdr) if n.strip()}
tot, gpu = [], []
for r in rows:
    try:
        if int(r[idx["Flags"]]) != 0: continue
        t = (int(r[idx["FrameCompleted"]]) - int(r[idx["IntendedVsync"]])) / 1e6
        g = (int(r[idx["GpuCompleted"]]) - int(r[idx["SwapBuffers"]])) / 1e6
        if 0 <= t < 1000: tot.append(t)
        if 0 <= g < 1000: gpu.append(g)
    except (KeyError, ValueError, IndexError):
        pass
def pct(v, p): return sorted(v)[min(len(v) - 1, int(len(v) * p))]
if tot:
    print(f"frames {len(tot)}  "
          f"p50 {pct(tot, .50):.2f}  p90 {pct(tot, .90):.2f}  "
          f"p95 {pct(tot, .95):.2f}  p99 {pct(tot, .99):.2f}  "
          f"max {max(tot):.2f} ms   (gpu p50 {pct(gpu, .50):.2f} ms)")
else:
    print("no frames captured")
EOF
echo
echo "DoD @250Hz: real-work median<=4ms p95<=4ms janky<5%; histogram floor at 250 Hz is 5ms (one vsync)"
