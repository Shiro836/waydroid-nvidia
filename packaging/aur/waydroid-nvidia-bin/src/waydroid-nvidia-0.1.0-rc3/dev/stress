#!/usr/bin/env bash
# stress — long-run stability soak: continuous UI churn (fling, app open/
# close, rotate through surfaces) while watching every layer for crashes.
# Pass criteria: zero venus-server restarts, zero render-worker crashes,
# zero new guest tombstones/ANRs, container stays up, KWin keeps binding.
# Usage: dev/stress [minutes]   (default 30)
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo
# env.sh sets -euo pipefail; a soak must survive its own probes failing
# (grep -q / head SIGPIPE the left side of pipes, probes return nonzero)
set +e +o pipefail

MINUTES="${1:-30}"
say "stress soak: ${MINUTES} min of continuous UI churn"

venus_pid_before=$(systemctl --user show wd-venus -p MainPID --value)
restarts_before=$(systemctl --user show wd-venus -p NRestarts --value)
tombs_before=$(guest "ls /data/tombstones 2>/dev/null | wc -l")
anrs_before=$(guest "ls /data/anr 2>/dev/null | wc -l")
guest "logcat -c" || true

end=$((SECONDS + MINUTES * 60))
iter=0
fail=0
while ((SECONDS < end)); do
    iter=$((iter + 1))
    guest "
      input keyevent KEYCODE_WAKEUP
      input swipe 1280 1200 1280 300 150; sleep 0.3
      for i in 1 2 3; do
        input swipe 1280 1100 1280 340 100; sleep 0.3
        input swipe 1280 340 1280 1100 100; sleep 0.3
      done
      am start -W com.android.settings/.Settings >/dev/null 2>&1; sleep 1
      input swipe 1280 1100 1280 400 200; sleep 0.3
      input keyevent KEYCODE_BACK; sleep 0.3
      input keyevent KEYCODE_HOME; sleep 0.3
    " >/dev/null 2>&1 || true
    # layer health every iteration (no pipes into grep -q: pipefail turns
    # grep's early exit into a SIGPIPE false negative)
    if ! systemctl --user is-active --quiet wd-venus; then
        say "!! wd-venus DOWN at iter $iter"; fail=1; break
    fi
    lxc_state=$(sudo -n lxc-info -P /var/lib/waydroid/lxc -n waydroid 2>/dev/null || true)
    if [[ "$lxc_state" != *RUNNING* ]]; then
        say "!! container DOWN at iter $iter"; fail=1; break
    fi
    if ((iter % 20 == 0)); then
        say "  iter $iter, $(( (end - SECONDS) / 60 )) min left"
    fi
done

echo
say "== results after $iter iterations"
venus_pid_after=$(systemctl --user show wd-venus -p MainPID --value)
restarts_after=$(systemctl --user show wd-venus -p NRestarts --value)
tombs_after=$(guest "ls /data/tombstones 2>/dev/null | wc -l")
anrs_after=$(guest "ls /data/anr 2>/dev/null | wc -l")
crashes=$(guest "logcat -d -b crash 2>/dev/null | grep -c 'FATAL EXCEPTION\|Fatal signal'" | head -1)
crashes=${crashes//[^0-9]/}; crashes=${crashes:-0}
render_crashes=$(journalctl --user -u wd-venus --since "-$((MINUTES + 2)) min" --no-pager 2>/dev/null \
    | { grep -ciE "segfault|crashed|core dump|abort" || true; })

echo "wd-venus:   pid $venus_pid_before -> $venus_pid_after, restarts $restarts_before -> $restarts_after"
echo "tombstones: $tombs_before -> $tombs_after   ANRs: $anrs_before -> $anrs_after"
echo "guest fatal crashes (logcat -b crash): $crashes"
echo "render-server crash lines (journal):   $render_crashes"

[ "$venus_pid_before" = "$venus_pid_after" ] || fail=1
[ "$restarts_before" = "$restarts_after" ] || fail=1
[ "$tombs_before" = "$tombs_after" ] || fail=1
[ "${crashes:-0}" -eq 0 ] || fail=1
[ "${render_crashes:-0}" -eq 0 ] || fail=1

if ((fail)); then say "!! STRESS FAIL"; exit 1; fi
say "== STRESS PASS: zero crashes across all layers"
