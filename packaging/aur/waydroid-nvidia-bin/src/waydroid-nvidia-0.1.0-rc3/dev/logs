#!/usr/bin/env bash
# logs — aggregate the logs that matter for GPU bring-up.
#   dev/logs        one-shot dump (waydroid.log tail + gfx-filtered logcat)
#   dev/logs -f     follow waydroid.log live
#   dev/logs gfx    logcat filtered to graphics init
#   dev/logs all    full logcat dump
#   dev/logs crash  crash buffer
#   dev/logs units  wd-venus / wd-container / wd-session journals
source "$(dirname "$(readlink -f "$0")")/env.sh"
set +e
LOG=/var/lib/waydroid/waydroid.log
GFX_RE='gralloc|Gralloc|EGL|egl|[Vv]ulkan|SurfaceFlinger|hwcomposer|hwc|libEGL|swiftshader|mesa|drm|minigbm|venus|ANGLE'

# waydroid.log is world-readable (0644) and the wheel group reads the system
# journal — no sudo needed for either. logcat goes through guest() (lxc-attach,
# NOPASSWD-allowlisted) instead of `sudo waydroid.py logcat` (bare sudo without
# a tty burns PAM attempts -> faillock; see STATE.md).
case "${1:-dump}" in
  -f)    exec tail -f "$LOG" ;;
  gfx)   guest 'logcat -d' | grep -E "$GFX_RE" ;;
  all)   exec guest 'logcat -d' ;;
  crash) exec guest 'logcat -d -b crash -t 400' ;;
  units)
    echo "===== $VENUS_UNIT (user) ====="; journalctl --user -u "$VENUS_UNIT" -n 40 --no-pager
    echo "===== $CONTAINER_UNIT ====="; journalctl -u "$CONTAINER_UNIT" -n 40 --no-pager
    echo "===== $SESSION_UNIT (user) ====="; journalctl --user -u "$SESSION_UNIT" -n 40 --no-pager
    ;;
  dump)
    echo "===== waydroid.log (tail) ====="
    tail -60 "$LOG" 2>/dev/null || echo "(no log)"
    echo; echo "===== logcat: graphics init ====="
    guest 'logcat -d' 2>/dev/null | grep -E "$GFX_RE" | tail -80 || echo "(logcat unavailable — container down?)"
    ;;
esac
