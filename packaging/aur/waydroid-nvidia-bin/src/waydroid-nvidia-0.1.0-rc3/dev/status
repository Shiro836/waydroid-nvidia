#!/usr/bin/env bash
# status — one-screen truth: what's running, which GPU path is active, host GPU.
source "$(dirname "$(readlink -f "$0")")/env.sh"
set +e
cd "$WAYDROID_SRC"
echo "===== waydroid status ====="
python3 waydroid.py status 2>/dev/null || echo "(session down)"
echo; echo "===== effective GPU props (waydroid_base.prop) ====="
grep -E 'gralloc|egl|vulkan' /var/lib/waydroid/waydroid_base.prop 2>/dev/null
echo; echo "===== in-container reality ====="
if have_sudo; then
    for p in ro.hardware.gralloc ro.hardware.egl ro.hardware.vulkan gralloc.gbm.device sys.boot_completed; do
        v=$(guest "getprop $p" 2>/dev/null | tr -d '\r')
        printf '%-28s %s\n' "$p" "${v:-<container down>}"
    done
    echo; echo "===== renderer actually used (SurfaceFlinger) ====="
    guest 'dumpsys SurfaceFlinger' 2>/dev/null | grep -iE 'GLES:|renderer|vulkan' | head -5
else
    echo "(sudo -n unavailable — waydroid-dev sudoers allowlist missing?)"
fi
echo; echo "===== host GPUs ====="
for d in /sys/class/drm/renderD*/device/uevent; do echo "$d: $(grep DRIVER $d)"; done
nvidia-smi --query-gpu=utilization.gpu,memory.used --format=csv,noheader 2>/dev/null | sed 's/^/5090: /' || true
