#!/usr/bin/env bash
# gamebench — GPU-bound load benchmark (the launcher fling in dev/measure is
# composition-bound and barely touches the GPU; this is the other axis, the
# one that differs between a 5090 and a 3050).
#
# Default mode runs tests/gpuload.c (NDK, EGL pbuffer, GLES2 via ANGLE ->
# Venus -> vtest -> host GPU): four scenes (fragment ALU, dependent texture
# fetches, blended overdraw, dense geometry), per-frame glFinish, fps each +
# geometric-mean score.  Deterministic, offscreen (nothing flashes on your
# desktop), no APK, no network.  Host GPU utilization is sampled during the
# run — near-100% = genuinely GPU-bound on this tier.
#
# App mode measures the real presented fps of ANY running app/game from
# SurfaceFlinger's frame timestamps (works for native GL/Vulkan apps where
# dumpsys gfxinfo shows nothing).
#
# Usage: dev/gamebench [W H SECS]        default 2560 1440 4
#        dev/gamebench app <pkg> [SECS]  fps of a running app (default 10 s)
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo
set +e +o pipefail

NDK_CLANG="${NDK_CLANG:-/opt/android-ndk/toolchains/llvm/prebuilt/linux-x86_64/bin/x86_64-linux-android34-clang}"
SRC="$WNV/tests/gpuload.c"
BIN="$WNV/tests/gpuload-android"

if [ "${1:-}" = "app" ]; then
    PKG="${2:?usage: dev/gamebench app <pkg> [secs]}"
    SECS="${3:-10}"
    say "app fps: $PKG for ${SECS}s (SurfaceFlinger TimeStats; the legacy"
    say "--latency frame table is dead on Android 13)"
    guest "dumpsys SurfaceFlinger --timestats -clear -enable" >/dev/null
    sleep "$SECS"
    DUMP="$(mktemp)"
    guest "dumpsys SurfaceFlinger --timestats -dump" > "$DUMP"
    python3 - "$PKG" "$DUMP" <<'PYEOF'
import re, sys
pkg, path = sys.argv[1], sys.argv[2]
# sections start at "layerName = "; pick pkg layers, prefer SurfaceView
best = None
for sec in open(path).read().split("layerName = ")[1:]:
    name = sec.splitlines()[0]
    if pkg not in name:
        continue
    m = re.search(r"totalFrames = (\d+)", sec)
    frames = int(m.group(1)) if m else 0
    key = ("SurfaceView" in name, frames)
    if frames and (best is None or key > best[0]):
        best = (key, name, sec)
if not best:
    print(f"no presenting layer for {pkg} — is it on screen and animating?")
    sys.exit(1)
_, name, sec = best
def g(pat):
    m = re.search(pat, sec)
    return m.group(1) if m else "?"
print(f"layer: {name}")
print(f"frames {g(r'totalFrames = (\d+)')}  dropped {g(r'droppedFrames = (\d+)')}  "
      f"janky {g(r'jankyFrames = (\d+)')}  avg fps {g(r'averageFPS = ([0-9.]+)')}")
m = re.search(r"present2present histogram is as below:\n([^\n]+)", sec)
if m:
    buckets = [(int(k), int(v)) for k, v in
               re.findall(r"(\d+)ms=(\d+)", m.group(1)) if int(v)]
    total = sum(v for _, v in buckets)
    acc, pct = 0, {}
    for ms, v in sorted(buckets):
        acc += v
        for p in (50, 90, 99):
            if p not in pct and acc >= total * p / 100:
                pct[p] = ms
    print(f"present2present p50 {pct.get(50)}ms  p90 {pct.get(90)}ms  "
          f"p99 {pct.get(99)}ms  (histogram, 1ms buckets)")
PYEOF
    rc=$?
    rm -f "$DUMP"
    guest "dumpsys SurfaceFlinger --timestats -disable" >/dev/null
    exit $rc
fi

W="${1:-2560}" H="${2:-1440}" SECS="${3:-4}"

# rebuild + push when the source is newer than the guest copy
if [ ! -f "$BIN" ] || [ "$SRC" -nt "$BIN" ]; then
    say "building gpuload ($NDK_CLANG)"
    "$NDK_CLANG" -O2 -o "$BIN" "$SRC" -lEGL -lGLESv2 -lm || exit 1
    sudo -n /usr/local/sbin/wd-deploy push "$BIN" gpuload-android || exit 1
elif ! guest "test -x /data/local/tmp/gpuload-android" 2>/dev/null; then
    sudo -n /usr/local/sbin/wd-deploy push "$BIN" gpuload-android || exit 1
fi

say "gpuload: ${W}x${H}, ${SECS}s/scene (offscreen, ANGLE->Venus->host GPU)"
UTIL_LOG="$(mktemp)"
trap 'rm -f "$UTIL_LOG"' EXIT
nvidia-smi --query-gpu=utilization.gpu,power.draw --format=csv,noheader -l 1 \
    > "$UTIL_LOG" 2>/dev/null &
SMI_PID=$!

guest "/data/local/tmp/gpuload-android $W $H $SECS"
rc=$?

kill "$SMI_PID" 2>/dev/null
echo
say "host GPU during run (util%, power)"
awk -F', ' 'NR>2 {print "  " $0}' "$UTIL_LOG" | sort | uniq -c | sort -rn | head -5
exit $rc
