#!/bin/bash
# wd-deploy — the single privileged helper for the Waydroid/NVIDIA dev loop.
# Runs as root via a narrow NOPASSWD sudoers rule. Every destination is a
# fixed, hardcoded path inside the Waydroid tree; sources are validated to
# live under the user's own home (realpath-normalized, so `..` can't escape).
# This replaces the previous broad `cp * /var/lib/waydroid/*`,
# `chmod * /...`, `patchelf *`, and `systemd-run *` NOPASSWD rules.
set -euo pipefail

WD=/var/lib/waydroid
NV=$WD/nv
USER_NAME=forsen
USER_HOME=/home/$USER_NAME
DATA=$USER_HOME/.local/share/waydroid

die() { echo "wd-deploy: $*" >&2; exit 1; }

# require_under REALPATH-OF-ARG  ALLOWED-PREFIX  [MORE-PREFIXES...]
require_under() {
    local rp="$1"; shift
    local p
    for p in "$@"; do
        [[ "$rp" == "$p"/* || "$rp" == "$p" ]] && return 0
    done
    die "path '$rp' not under allowed prefix(es): $*"
}

# a plain filename with no path separators
require_basename() {
    [[ "$1" == "$(basename -- "$1")" && "$1" != /* && "$1" != *..* ]] \
        || die "'$1' must be a bare filename"
}

src_realpath() {
    local rp; rp="$(realpath -m -- "$1")" || die "cannot resolve '$1'"
    [[ -f "$rp" ]] || die "source '$rp' is not a regular file"
    require_under "$rp" "$USER_HOME" "/tmp/claude-1000"
    printf '%s' "$rp"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  # Install a built guest library into /var/lib/waydroid/nv/<name>
  lib)
    [[ $# -eq 2 ]] || die "usage: lib <src> <name>"
    src="$(src_realpath "$1")"; name="$2"; require_basename "$name"
    install -o root -g root -m 0644 "$src" "$NV/$name"
    echo "installed $NV/$name"
    ;;
  # Install a built guest executable into /var/lib/waydroid/nv/<name> (0755;
  # e.g. the patched surfaceflinger bind-mounted over system/bin)
  bin)
    [[ $# -eq 2 ]] || die "usage: bin <src> <name>"
    src="$(src_realpath "$1")"; name="$2"; require_basename "$name"
    install -o root -g root -m 0755 "$src" "$NV/$name"
    echo "installed $NV/$name"
    ;;
  # Install the guest Venus driver into the vendor overlay
  overlay-vulkan)
    [[ $# -eq 1 ]] || die "usage: overlay-vulkan <src>"
    src="$(src_realpath "$1")"
    dst="$WD/overlay/vendor/lib64/hw/vulkan.virtio.so"
    install -o root -g root -m 0644 "$src" "$dst"
    echo "installed $dst"
    ;;
  # Replace the LXC per-node mount config
  config-nodes)
    [[ $# -eq 1 ]] || die "usage: config-nodes <src>"
    src="$(src_realpath "$1")"
    install -o root -g root -m 0644 "$src" "$WD/lxc/waydroid/config_nodes"
    echo "installed config_nodes"
    ;;
  # Replace the waydroid.cfg (props merged into base.prop on upgrade)
  cfg)
    [[ $# -eq 1 ]] || die "usage: cfg <src>"
    src="$(src_realpath "$1")"
    install -o root -g root -m 0644 "$src" "$WD/waydroid.cfg"
    echo "installed waydroid.cfg"
    ;;
  # Push a file into the guest-visible /data/local/tmp (uid 2000 tree)
  push)
    [[ $# -eq 1 || $# -eq 2 ]] || die "usage: push <src> [name]"
    src="$(src_realpath "$1")"
    name="${2:-$(basename -- "$1")}"; require_basename "$name"
    install -o 2000 -g 2000 -m 0755 "$src" "$DATA/data/local/tmp/$name"
    echo "pushed $DATA/data/local/tmp/$name"
    ;;
  # Copy a file out of the (uid 2000) waydroid data dir to the user's home.
  pull)
    [[ $# -eq 2 ]] || die "usage: pull <guest-data-file> <host-dest>"
    src="$(realpath -m -- "$1")"; dst="$(realpath -m -- "$2")"
    require_under "$src" "$DATA"
    require_under "$dst" "$USER_HOME"
    [[ "$dst" == "$DATA"/* ]] && die "dest must be outside the data dir"
    install -o "$USER_NAME" -g "$USER_NAME" -m 0644 "$src" "$dst"
    echo "pulled to $dst"
    ;;
  *)
    die "unknown subcommand '$cmd' (lib|bin|overlay-vulkan|config-nodes|cfg|push|pull)"
    ;;
esac
