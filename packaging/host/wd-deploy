#!/bin/bash
# wd-deploy — the single privileged helper for the Waydroid/NVIDIA dev loop.
# Runs as root via a narrow NOPASSWD sudoers rule. Every destination is a
# fixed, hardcoded path inside the Waydroid tree; sources are validated to
# live under the user's own home (realpath-normalized, so `..` can't escape).
# This replaces the previous broad `cp * /var/lib/waydroid/*`,
# `chmod * /...`, `patchelf *`, and `systemd-run *` NOPASSWD rules.
set -euo pipefail

WD=/var/lib/waydroid
NV=$WD/nv
USER_NAME="${SUDO_USER:-}"
[[ -n "$USER_NAME" && "$USER_NAME" != root ]] || {
    echo "wd-deploy: invoke through sudo so the calling desktop user is known" >&2
    exit 1
}
USER_HOME=$(getent passwd "$USER_NAME" | cut -d: -f6)
[[ -n "$USER_HOME" ]] || {
    echo "wd-deploy: cannot resolve home directory for '$USER_NAME'" >&2
    exit 1
}
DATA=$USER_HOME/.local/share/waydroid

die() { echo "wd-deploy: $*" >&2; exit 1; }

# require_under REALPATH-OF-ARG  ALLOWED-PREFIX  [MORE-PREFIXES...]
require_under() {
    local rp="$1"; shift
    local p
    for p in "$@"; do
        [[ "$rp" == "$p"/* || "$rp" == "$p" ]] && return 0
    done
    die "path '$rp' not under allowed prefix(es): $*"
}

# a plain filename with no path separators
require_basename() {
    [[ "$1" == "$(basename -- "$1")" && "$1" != /* && "$1" != *..* ]] \
        || die "'$1' must be a bare filename"
}

src_realpath() {
    local rp; rp="$(realpath -m -- "$1")" || die "cannot resolve '$1'"
    [[ -f "$rp" ]] || die "source '$rp' is not a regular file"
    require_under "$rp" "$USER_HOME" "/tmp/claude-1000"
    printf '%s' "$rp"
}

require_android_elf() {
    local src="$1" abi="$2" expected_soname="$3"
    local expected_class expected_machine header dynamic actual_soname
    case "$abi" in
      x86) expected_class=ELF32; expected_machine="Intel 80386" ;;
      x86_64) expected_class=ELF64; expected_machine="Advanced Micro Devices X86-64" ;;
      *) die "unsupported guest ABI '$abi'" ;;
    esac
    command -v readelf >/dev/null 2>&1 || die "readelf is required (install binutils)"
    header=$(LC_ALL=C readelf -hW -- "$src" 2>/dev/null) ||
        die "$src is not a complete ELF file"
    if ! grep -Eq "^[[:space:]]*Class:[[:space:]]+${expected_class}[[:space:]]*$" <<<"$header" ||
       ! grep -Eq "^[[:space:]]*Machine:[[:space:]]+${expected_machine}[[:space:]]*$" <<<"$header" ||
       ! grep -Eq '^[[:space:]]*Type:[[:space:]]+DYN([[:space:]]|$)' <<<"$header"; then
        die "$src is not an $expected_class/$expected_machine shared object"
    fi
    dynamic=$(LC_ALL=C readelf -dW -- "$src" 2>/dev/null) ||
        die "cannot read the dynamic section from $src"
    actual_soname=$(sed -n 's/.*(SONAME).*Library soname: \[\([^]]*\)\].*/\1/p' <<<"$dynamic")
    [ "$actual_soname" = "$expected_soname" ] ||
        die "$src has SONAME '${actual_soname:-<missing>}' (expected '$expected_soname')"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  # Install an app-ABI guest driver into the path-preserving layout. The
  # kind allowlist prevents a privileged caller from choosing an arbitrary
  # destination below /var/lib/waydroid.
  guest-lib)
    [[ $# -eq 3 ]] || die "usage: guest-lib <x86|x86_64> <vulkan|egl|gles1|gles2|gralloc|hwcomposer> <src>"
    abi="$1"; kind="$2"; src="$(src_realpath "$3")"
    case "$abi" in
      x86) libdir=lib ;;
      x86_64) libdir=lib64 ;;
      *) die "unsupported guest ABI '$abi' (want x86 or x86_64)" ;;
    esac
    case "$kind" in
      vulkan) rel="vendor/$libdir/hw/vulkan.virtio.so"; soname=libvulkan_virtio.so ;;
      egl)    rel="vendor/$libdir/egl/libEGL_angle.so"; soname=libEGL_angle.so ;;
      gles1)  rel="vendor/$libdir/egl/libGLESv1_CM_angle.so"; soname=libGLESv1_CM_angle.so ;;
      gles2)  rel="vendor/$libdir/egl/libGLESv2_angle.so"; soname=libGLESv2_angle.so ;;
      gralloc)
        [[ "$abi" == x86_64 ]] || die "gralloc is a 64-bit system-service library"
        rel="vendor/lib64/libgbm_mesa_wrapper.so"
        soname=libgbm_mesa_wrapper.so
        ;;
      hwcomposer)
        [[ "$abi" == x86_64 ]] || die "hwcomposer is a 64-bit system-service library"
        rel="vendor/lib64/hw/hwcomposer.waydroid.so"
        soname=hwcomposer.waydroid.so
        ;;
      *) die "unsupported guest library kind '$kind'" ;;
    esac
    require_android_elf "$src" "$abi" "$soname"
    dst="$NV/guest/$rel"
    grep -Eq '^[[:space:]]*nvidia_guest_layout[[:space:]]*=[[:space:]]*2[[:space:]]*$' \
        "$WD/waydroid.cfg" ||
        die "dual-ABI guest layout is not enabled; run the current waydroid-nvidia-setup first"
    grep -Fq "lxc.mount.entry = $dst $rel " "$WD/lxc/waydroid/config_nodes" ||
        die "generated container config does not mount $rel from the dual-ABI guest tree; run waydroid upgrade -o"
    install -o root -g root -m 0644 -D "$src" "$dst"
    echo "installed $dst"
    ;;
  # Install a built guest library into /var/lib/waydroid/nv/<name>
  lib)
    [[ $# -eq 2 ]] || die "usage: lib <src> <name>"
    src="$(src_realpath "$1")"; name="$2"; require_basename "$name"
    install -o root -g root -m 0644 "$src" "$NV/$name"
    echo "installed $NV/$name"
    ;;
  # Install a built guest executable into /var/lib/waydroid/nv/<name> (0755;
  # e.g. the patched surfaceflinger bind-mounted over system/bin)
  bin)
    [[ $# -eq 2 ]] || die "usage: bin <src> <name>"
    src="$(src_realpath "$1")"; name="$2"; require_basename "$name"
    install -o root -g root -m 0755 "$src" "$NV/$name"
    echo "installed $NV/$name"
    ;;
  # Install the guest Venus driver into the vendor overlay
  overlay-vulkan)
    [[ $# -eq 1 ]] || die "usage: overlay-vulkan <src>"
    src="$(src_realpath "$1")"
    dst="$WD/overlay/vendor/lib64/hw/vulkan.virtio.so"
    install -o root -g root -m 0644 "$src" "$dst"
    echo "installed $dst"
    ;;
  # Replace the LXC per-node mount config
  config-nodes)
    [[ $# -eq 1 ]] || die "usage: config-nodes <src>"
    src="$(src_realpath "$1")"
    install -o root -g root -m 0644 "$src" "$WD/lxc/waydroid/config_nodes"
    echo "installed config_nodes"
    ;;
  # Replace the waydroid.cfg (props merged into base.prop on upgrade)
  cfg)
    [[ $# -eq 1 ]] || die "usage: cfg <src>"
    src="$(src_realpath "$1")"
    install -o root -g root -m 0644 "$src" "$WD/waydroid.cfg"
    echo "installed waydroid.cfg"
    ;;
  # Push a file into the guest-visible /data/local/tmp (uid 2000 tree)
  push)
    [[ $# -eq 1 || $# -eq 2 ]] || die "usage: push <src> [name]"
    src="$(src_realpath "$1")"
    name="${2:-$(basename -- "$1")}"; require_basename "$name"
    install -o 2000 -g 2000 -m 0755 "$src" "$DATA/data/local/tmp/$name"
    echo "pushed $DATA/data/local/tmp/$name"
    ;;
  # Copy a file out of the (uid 2000) waydroid data dir to the user's home.
  pull)
    [[ $# -eq 2 ]] || die "usage: pull <guest-data-file> <host-dest>"
    src="$(realpath -m -- "$1")"; dst="$(realpath -m -- "$2")"
    require_under "$src" "$DATA"
    require_under "$dst" "$USER_HOME"
    [[ "$dst" == "$DATA"/* ]] && die "dest must be outside the data dir"
    install -o "$USER_NAME" -g "$USER_NAME" -m 0644 "$src" "$dst"
    echo "pulled to $dst"
    ;;
  *)
    die "unknown subcommand '$cmd' (guest-lib|lib|bin|overlay-vulkan|config-nodes|cfg|push|pull)"
    ;;
esac
