#!/usr/bin/env bash
# sync-patches — regenerate patches/ and net-new src/ in THIS repo from the
# working trees, so the AUR build (clone BASE -> apply series -> build)
# reproduces exactly what was tested. Run before every commit of a code change.
# Does NOT commit — prints a git-status summary for you to review.
#
# Anchors (env.sh): committed commits -> numbered patches via format-patch;
# uncommitted WIP -> a single trailing wip patch via git diff.
source "$(dirname "$(readlink -f "$0")")/env.sh"

fmt() { # tree base outdir   -> numbered patches for committed commits
    git -C "$1" format-patch "$2..HEAD" -o "$3" -q
}
diffto() { # tree outfile [pathspec...]  -> uncommitted tracked diff
    local t="$1" o="$2"; shift 2
    git -C "$t" diff -- "$@" > "$o"
}

say "mesa: 0001,0002 (committed) + 0003 (wip)"
fmt "$MESA_TREE" "$MESA_BASE" "$REPO/patches/mesa"
diffto "$MESA_TREE" "$REPO/patches/mesa/0003-wip-ahb-memory-steering.patch"

say "virglrenderer: 0001-0003 (committed) + 0004 (wip) + net-new src"
fmt "$VIRGL_TREE" "$VIRGL_BASE" "$REPO/patches/virglrenderer"
# 0004 = tracked WIP only (untracked gpu-alloc files are shipped as net-new src)
diffto "$VIRGL_TREE" "$REPO/patches/virglrenderer/0004-wip-gpu-alloc-and-global-priority.patch"
cp "$VIRGL_TREE/vtest/vtest_gpu_alloc.c" "$REPO/src/virglrenderer-vtest/"
cp "$VIRGL_TREE/vtest/vtest_gpu_alloc.h" "$REPO/src/virglrenderer-vtest/"
[ -f "$VIRGL_TREE/vtest/vtest_alloc_formats.h" ] && cp "$VIRGL_TREE/vtest/vtest_alloc_formats.h" "$REPO/src/"

say "hwcomposer: 0001-wip-nvidia-fixes (all uncommitted)"
diffto "$HWC_TREE" "$REPO/patches/hwcomposer/0001-wip-nvidia-fixes.patch"

say "waydroid: 0001-nvidia-integration (uncommitted gpu.py + lxc.py + hardware_manager.py + session_manager.py)"
diffto "$WAYDROID_SRC" "$REPO/patches/waydroid/0001-nvidia-integration.patch" \
    tools/helpers/gpu.py tools/helpers/lxc.py tools/services/hardware_manager.py \
    tools/actions/session_manager.py

echo
say "review (nothing committed):"
git -C "$REPO" status --short patches/ src/
echo
echo "diff summary:"; git -C "$REPO" diff --stat patches/ src/ | tail -20
echo
echo "if it looks right:  git -C $REPO add -A patches/ src/ && git -C $REPO commit"
