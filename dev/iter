#!/usr/bin/env bash
# iter — the no-bs one-shot: build -> deploy -> full restart -> health -> measure
# for one component. This is the change->test loop in a single command.
#   dev/iter mesa        # rebuild guest venus, redeploy, restart, measure
#   dev/iter hwc
#   dev/iter virgl       # host renderer (restarts wd-venus + full stack)
#   dev/iter none        # just restart + health + measure (e.g. after a prop/cfg change)
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo
DEV="$REPO/dev"

comp="${1:-none}"
if [ "$comp" != none ]; then
    "$DEV/build"  "$comp"
    "$DEV/deploy" "$comp"
fi
"$DEV/restart"
echo; "$DEV/health"
echo; "$DEV/measure"
