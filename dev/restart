#!/usr/bin/env bash
# restart — the ONE allowed way to bounce the stack (never kill composer/SF
# individually; SF zombies at flips=0). Full clean restart of the venus
# renderer + container + session, operating on the runtime waydroid checkout.
#   edit code/props -> dev/build+deploy -> dev/restart -> dev/measure
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo
cd "$WAYDROID_SRC"

say "stopping session / container"
systemctl --user stop "$SESSION_UNIT" 2>/dev/null || true
python3 waydroid.py session stop 2>/dev/null || true
sudo -n systemctl stop "$CONTAINER_UNIT" 2>/dev/null || true
sleep 1

say "restarting venus renderer ($VENUS_UNIT)"
systemctl --user restart "$VENUS_UNIT"

say "starting container ($CONTAINER_UNIT)"
sudo -n systemctl restart "$CONTAINER_UNIT"
sleep 2

say "starting session (transient user unit, keeps Wayland env)"
systemd-run --user --unit="${SESSION_UNIT%.service}" --collect \
    --working-directory="$WAYDROID_SRC" \
    --setenv=WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}" \
    --setenv=XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" \
    python3 waydroid.py session start
sleep 1

say "waiting for boot (max 120s)"
booted=
for i in $(seq 1 60); do
    booted=$(python3 waydroid.py prop get sys.boot_completed 2>/dev/null | tr -d '\r')
    [ "$booted" = 1 ] && { say "BOOTED after ~$((i*2))s"; break; }
    sleep 2
done
[ "$booted" = 1 ] || warn "did not reach boot_completed=1 — check dev/logs"

# map the window on the monitor
python3 waydroid.py show-full-ui 2>/dev/null || true
