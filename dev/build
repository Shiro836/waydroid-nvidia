#!/usr/bin/env bash
# build — compile one (or all) native component(s) by calling the shared build
# recipe (build/<comp>/build.sh) against the PERSISTENT working tree
# (incremental). packaging/aur reproduce.sh calls the SAME recipes against a
# fresh checkout — one recipe, two front-ends. Does NOT deploy (see dev/deploy).
# Usage: dev/build <mesa|virgl|hwc|gralloc|angle|all>
source "$(dirname "$(readlink -f "$0")")/env.sh"
B="$REPO/build"

case "${1:-}" in
    mesa)    say "mesa (guest venus driver)";  "$B/mesa/build.sh"  "$MESA_TREE" "$MESA_BUILD" ;;
    virgl)   say "virglrenderer (host renderer)"; REPO="$REPO" "$B/virglrenderer/build.sh" "$VIRGL_TREE" "$VIRGL_BUILD" ;;
    hwc)     say "hwcomposer"; "$B/hwcomposer/build.sh" "$HWC_TREE/hwcomposer" "$HWC_BUILD/out" ;;
    gralloc) say "gralloc backend"; REPO="$REPO" "$B/gralloc/build.sh" "$HWC_BUILD/out" ;;
    angle)   say "ANGLE (rare, slow)"
             "$ANGLE_TREE/third_party/ninja/ninja" -C "$ANGLE_TREE/out/AndroidX64" \
                 libEGL libGLESv2 libGLESv1_CM
             echo "  -> $ANGLE_TREE/out/AndroidX64/lib{EGL,GLESv2,GLESv1_CM}_angle.so" ;;
    all)     "$0" mesa; "$0" virgl; "$0" hwc ;;
    *) die "usage: dev/build <mesa|virgl|hwc|gralloc|angle|all>" ;;
esac
