#!/usr/bin/env bash
# deploy — install a freshly built component into the running Waydroid tree via
# the narrow privileged helper (wd-deploy). Guest .so's need a FULL restart
# afterwards (dev/restart) — a bind-mounted lib keeps its old inode until then.
# Usage: dev/deploy <mesa[-x86|-x86_64]|virgl|hwc|angle[-x86|-x86_64]|gralloc>
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo

case "${1:-}" in
    mesa) "$0" mesa-x86_64; "$0" mesa-x86 ;;
    mesa-x86_64)
        sudo -n "$DEPLOY" guest-lib x86_64 vulkan \
            "$MESA_BUILD_X86_64/src/virtio/vulkan/libvulkan_virtio.so"
        warn "guest lib deployed — run dev/restart for the container to pick it up" ;;
    mesa-x86)
        sudo -n "$DEPLOY" guest-lib x86 vulkan \
            "$MESA_BUILD_X86/src/virtio/vulkan/libvulkan_virtio.so"
        warn "guest lib deployed — run dev/restart for the container to pick it up" ;;
    hwc)
        sudo -n "$DEPLOY" guest-lib x86_64 hwcomposer \
            "$HWC_BUILD/out/hwcomposer.waydroid.stripped.so"
        warn "guest lib deployed — run dev/restart" ;;
    angle) "$0" angle-x86_64; "$0" angle-x86 ;;
    angle-x86_64)
        for f in EGL GLESv2 GLESv1_CM; do
            case "$f" in EGL) kind=egl ;; GLESv1_CM) kind=gles1 ;; GLESv2) kind=gles2 ;; esac
            sudo -n "$DEPLOY" guest-lib x86_64 "$kind" \
                "$ANGLE_OUT_X86_64/lib${f}_angle.so"
        done
        warn "guest libs deployed — run dev/restart" ;;
    angle-x86)
        for f in EGL GLESv2 GLESv1_CM; do
            case "$f" in EGL) kind=egl ;; GLESv1_CM) kind=gles1 ;; GLESv2) kind=gles2 ;; esac
            sudo -n "$DEPLOY" guest-lib x86 "$kind" \
                "$ANGLE_OUT_X86/lib${f}_angle.so"
        done
        warn "guest libs deployed — run dev/restart" ;;
    virgl)
        # host-side renderer: runs from its build dir via the user unit.
        say "restart $VENUS_UNIT (host renderer picks up the new build)"
        systemctl --user restart "$VENUS_UNIT"
        warn "renderer restarted — run dev/restart so the stack reconnects" ;;
    gralloc)
        sudo -n "$DEPLOY" guest-lib x86_64 gralloc \
            "$HWC_BUILD/out/libgbm_mesa_wrapper.so"
        warn "guest lib deployed — run dev/restart" ;;
    *) die "usage: dev/deploy <mesa[-x86|-x86_64]|virgl|hwc|angle[-x86|-x86_64]|gralloc>" ;;
esac
